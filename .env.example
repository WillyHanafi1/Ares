# Seriaflow Website Configuration


# n8n Webhook URL for Lead Capture (Contact Form)
PUBLIC_WEBHOOK_URL=your_webhook
# n8n Webhook URL for Resource Downloads
PUBLIC_RESOURCES_WEBHOOK_URL=your_webhook
# Google reCAPTCHA v3
# Get keys from: https://www.google.com/recaptcha/admin
PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here

# WhatsApp Number
PUBLIC_WHATSAPP_NUMBER=your_whatsapp_number_here


# Rate Limiting Configuration
# RATE_LIMIT_MAX: Maximum requests allowed per window (default: 5)
# RATE_LIMIT_WINDOW: Time window in milliseconds (default: 600000 = 10 minutes)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=600000
 
# Mode Admin Resource
ADMIN_TOKEN=your_admin_token_here
