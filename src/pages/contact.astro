---
export const prerender = true;
import Layout from "@/layouts/Layout.astro";
import { Navbar } from "@/components/blocks/navbar";
import { Footer } from "@/components/blocks/footer";
import ContactSection from "@/components/blocks/contact";

import { Background } from "@/components/background";
---

<Layout
    title="Kontak — Seriaflow AI Automation Agency"
    description="Hubungi tim Seriaflow untuk konsultasi gratis tentang solusi AI automation untuk bisnis Anda."
>
    <Navbar client:load />

    <Background className="via-muted to-muted/80">
        <div data-reveal>
            <ContactSection client:visible />
        </div>
    </Background>

    <div data-reveal>
        <Footer />
    </div>
</Layout>
