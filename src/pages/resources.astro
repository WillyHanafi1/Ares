---
import Layout from "@/layouts/Layout.astro";
import { Navbar } from "@/components/blocks/navbar";
import { Footer } from "@/components/blocks/footer";
import { Resources as ResourcesSection } from "@/components/blocks/resources";

import { Background } from "@/components/background";

// Server-side: exchange query param for cookie, then clean redirect
Astro.response.headers.set("Cache-Control", "no-store");

const adminToken = Astro.url.searchParams.get("admin");
const expectedToken = import.meta.env.ADMIN_TOKEN;

// 1. If URL has the correct token, set cookie and redirect
if (adminToken && expectedToken && adminToken === expectedToken) {
    Astro.cookies.set("admin_session", expectedToken, {
        path: "/",
        httpOnly: true,
        secure: import.meta.env.PROD, // secure only in production so localhost works
        sameSite: "strict",
        maxAge: 60 * 60 * 24, // 1 day
    });

    // Clean redirect to hide the token from browser history/URL bar
    return Astro.redirect("/resources", 302);
}

// 2. Check if user is already authenticated via cookie
const adminSession = Astro.cookies.get("admin_session")?.value;
const hasValidCookie = !!expectedToken && adminSession === expectedToken;

// Tampilkan admin panel jika cookie valid ATAU jika user ingin login via ?admin
const wantsToLogin = Astro.url.searchParams.has("admin");
const showAdminLogin = hasValidCookie || wantsToLogin;
---

<Layout
    title="Resources — Seriaflow AI Automation Agency"
    description="Download panduan, template, dan resource gratis dari Seriaflow untuk memulai automasi bisnis Anda."
>
    <Navbar client:load />

    <Background className="via-muted to-muted/80">
        <div data-reveal>
            <ResourcesSection client:visible isAdmin={showAdminLogin} />
        </div>
    </Background>

    <div data-reveal>
        <Footer />
    </div>
</Layout>
