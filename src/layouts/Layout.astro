---
import { ClientRouter } from "astro:transitions";
import "@/styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Seriaflow — AI Automation Agency",
  description = "Hemat waktu dan biaya operasional bisnis Anda dengan AI automation dari Seriaflow.",
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Astro View Transitions (SPA page transitions) -->
    <ClientRouter />

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <!-- Theme initialization: runs immediately to prevent FOUC. Default = dark. -->
    <script is:inline>
      const getTheme = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return "dark";
      };
      const applyTheme = (doc) => {
        const theme = getTheme();
        if (theme === "dark") {
          doc.documentElement.classList.add("dark");
        } else {
          doc.documentElement.classList.remove("dark");
        }
      };
      applyTheme(document);
      document.addEventListener("astro:before-swap", (ev) => {
        applyTheme(ev.newDocument);
      });
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1313EC" />

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/og-image.png", Astro.site)} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Seriaflow" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og-image.png", Astro.site)} />

    <!-- JSON-LD Organization -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Seriaflow",
        "url": "https://seriaflow.com",
        "logo": "https://seriaflow.com/favicon.png",
        "description": "AI Automation Agency Indonesia - Hemat waktu dan biaya operasional bisnis Anda.",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+62-851-1762-3819",
          "contactType": "sales",
          "areaServed": "ID",
          "availableLanguage": ["Indonesian", "English"]
        }
      }
    </script>

    <!-- Google Fonts: Inter (body) + Plus Jakarta Sans (headings) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="min-h-screen bg-background font-sans antialiased overflow-x-hidden"
  >
    <slot />

    <!-- Scroll Reveal Observer — re-runs after every Astro View Transition -->
    <script>
      function initScrollReveal() {
        const targets = document.querySelectorAll(
          "[data-reveal], [data-reveal-stagger]",
        );
        if (!targets.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const el = entry.target;
              const rect = entry.boundingClientRect;
              if (entry.isIntersecting) {
                el.classList.add("revealed");
                el.classList.remove("exited");
              } else if (rect.top < 0) {
                el.classList.add("exited");
                el.classList.remove("revealed");
              } else {
                el.classList.remove("revealed");
                el.classList.remove("exited");
              }
            });
          },
          { threshold: [0, 0.12, 0.5], rootMargin: "0px 0px -40px 0px" },
        );

        targets.forEach((el) => observer.observe(el));
      }

      initScrollReveal();
      document.addEventListener("astro:page-load", initScrollReveal);
    </script>
  </body>
</html>
